    # Fast Models
    "kilo-minimax": ("kilo", "minimax/minimax-m2.5:free", "MiniMax M2.5 (free, 204K ctx, fast)"),
    "kilo-trinity": ("kilo", "arcee-ai/trinity-large-preview:free", "Arcee Trinity Large (free, 131K ctx, reliable)"),
    
    # Additional Free Models
    "kilo-nemotron": ("kilo", "nvidia/nemotron-3-super-120b-a12b:free", "NVIDIA Nemotron 120B (free, 262K ctx)"),
    "kilo-stepfun": ("kilo", "stepfun/step-3.5-flash:free", "StepFun Step-3.5-Flash (free, 256K ctx)"),
    "kilo-corethink": ("kilo", "corethink:free", "CoreThink (free, 78K ctx)"),
    "kilo-auto-free": ("kilo", "kilo-auto/free", "Kilo Auto Free (free, auto-routed best model)"),
