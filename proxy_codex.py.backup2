    "gpt-5": "kilo-mimo-v2-pro",
    "gpt-5-codex": "kilo-mimo-v2-pro",
    
    # GPT-4 Series
    "gpt-4o": "kilo-mimo-v2-pro",
    "gpt-4o-mini": "kilo-minimax",
